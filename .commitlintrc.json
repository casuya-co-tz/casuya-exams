{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      ["feat", "fix", "docs", "style", "refactor", "perf", "test", "chore", "revert", "build", "ci"]
    ],
    "scope-enum": [
      2,
      "always",
      [
        "question-bank",
        "exam-builder",
        "scheduling",
        "sessions",
        "grading",
        "reports",
        "certificates",
        "analytics",
        "security",
        "utils",
        "tests",
        "docs"
      ]
    ],
    "subject-case": [0]
  }
}
