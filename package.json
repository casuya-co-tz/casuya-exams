{
  "name": "casuya-exams",
  "version": "0.1.0",
  "description": "Examination Department — Complete digital assessment capabilities for Casuya",
  "license": "MIT",
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "lint": "eslint src/ tests/ --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "jest --config jest.config.js",
    "test:unit": "jest --config jest.config.js --testPathPattern='tests/unit'",
    "test:integration": "jest --config jest.config.js --testPathPattern='tests/integration'",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "update:github": "node scripts/update-github-metadata.js",
    "prepublishOnly": "npm run clean && npm run build && npm run test"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "education",
    "exams",
    "assessment",
    "grading",
    "certification",
    "casuya",
    "testing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/casuya/casuya-exams.git"
  },
  "bugs": {
    "url": "https://github.com/casuya/casuya-exams/issues"
  },
  "homepage": "https://github.com/casuya/casuya-exams#readme",
  "dependencies": {
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^27.6.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  }
}
